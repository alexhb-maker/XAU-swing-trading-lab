//@version=6
indicator(
     title             = "EMA Gold Trader 2026",
     shorttitle        = "EMA-GT_26",
     overlay           = true
)

// PARAMETERS
emaPeriod      = input.int  (60,   "EMA Period",              minval=1,            group="Indicators")
demaPeriod     = input.int  (60,   "DEMA Period",             minval=1,            group="Indicators")
ema200Period   = input.int  (200,  "EMA 200 Period",          minval=1,            group="Indicators")
swLookback     = input.int  (10,   "Level lookback",          minval=3, maxval=50, group="Liquidity Sweep")
wickRatio      = input.float(0.55, "Minimum wick ratio",      minval=0.3, maxval=0.9, step=0.05, group="Liquidity Sweep")
sweepBoxBars   = input.int  (8,    "Box duration (bars)",     minval=1,            group="Liquidity Sweep")
showBullSweep  = input.bool (true, "Show bullish sweep",                          group="Liquidity Sweep")
showBearSweep  = input.bool (true, "Show bearish sweep",                          group="Liquidity Sweep")

// INDICATORS
ema  = ta.ema(close, emaPeriod)
ema1 = ta.ema(close, demaPeriod)
dema = 2.0 * ema1 - ta.ema(ema1, demaPeriod)
ema200 = ta.ema(close, ema200Period)

plot(ema,    "EMA",     color=color.new(color.orange, 0), linewidth=2)
plot(dema,   "DEMA",    color=color.new(color.blue,   0), linewidth=2)
plot(ema200, "EMA 200", color=color.new(color.white,  0), linewidth=2)

// BUY SIGNAL — CONSERVATIVE
// Requires: previous close > EMA and previous close > DEMA
buySignal = close[1] > ema[1] and close[1] > dema[1]

// EMA/DEMA CROSS — yellow visual when EMA crosses above DEMA
emaCrossAbove = ema[1] <= dema[1] and ema > dema

// VISUALS — TRIANGLES
// Green: valid BUY entry
plotshape(buySignal,
     title="BUY", style=shape.triangleup, location=location.belowbar,
     color=color.lime, size=size.tiny)

// Yellow: EMA crosses above DEMA (trend confirmation)
plotshape(emaCrossAbove,
     title="EMA > DEMA", style=shape.triangleup, location=location.abovebar,
     color=color.new(color.yellow, 0), size=size.tiny)

// LIQUIDITY SWEEPS
recentLow  = ta.lowest (low,  swLookback)[1]
recentHigh = ta.highest(high, swLookback)[1]
barRange   = high - low

wickLow  = math.min(open, close) - low
bullSweep = showBullSweep and close >= open and low <= recentLow
         and barRange > 0 and wickLow / barRange >= wickRatio

wickHigh  = high - math.max(open, close)
bearSweep = showBearSweep and close <= open and high >= recentHigh
         and barRange > 0 and wickHigh / barRange >= wickRatio

if bullSweep
    box.new(left=bar_index, top=math.max(open,close), right=bar_index+sweepBoxBars, bottom=low,
         border_color=color.new(color.lime,20), bgcolor=color.new(color.lime,82),
         text="Sweep BUY", text_color=color.new(color.lime,0), text_size=size.tiny)

if bearSweep
    box.new(left=bar_index, top=high, right=bar_index+sweepBoxBars, bottom=math.min(open,close),
         border_color=color.new(color.red,20), bgcolor=color.new(color.red,82),
         text="Sweep SELL", text_color=color.new(color.red,0), text_size=size.tiny)

// STATUS TABLE
var table tbl = table.new(position.top_right, 2, 7,
     bgcolor=color.new(color.black,75), border_width=1,
     border_color=color.new(color.gray,60))

if barstate.islast
    table.cell(tbl, 0, 0, "EMA 60", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 0, str.tostring(math.round(ema, 2)), text_color=color.orange, text_size=size.small)

    table.cell(tbl, 0, 1, "DEMA 60", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 1, str.tostring(math.round(dema, 2)), text_color=color.aqua, text_size=size.small)

    table.cell(tbl, 0, 2, "EMA 200", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 2, str.tostring(math.round(ema200, 2)), text_color=color.white, text_size=size.small)

    buyTxt = buySignal ? "YES" : "NO"
    buyCol = buySignal ? color.lime : color.gray
    table.cell(tbl, 0, 3, "BUY Signal", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 3, buyTxt, text_color=buyCol, text_size=size.small)

    sweepTxt = bullSweep ? "BUY zone" : bearSweep ? "SELL zone" : "-"
    sweepCol = bullSweep ? color.lime : bearSweep ? color.red : color.gray
    table.cell(tbl, 0, 4, "Sweep", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 4, sweepTxt, text_color=sweepCol, text_size=size.small)

    crossTxt = emaCrossAbove ? "YES" : "NO"
    crossCol = emaCrossAbove ? color.yellow : color.gray
    table.cell(tbl, 0, 5, "EMA > DEMA", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 5, crossTxt, text_color=crossCol, text_size=size.small)

    table.cell(tbl, 0, 6, "Price", text_color=color.silver, text_size=size.small)
    table.cell(tbl, 1, 6, str.tostring(math.round(close, 2)), text_color=color.aqua, text_size=size.small)

// === SHORT SIGNAL === extra info
sellSignal = close[1] < ema and close[1] < dema

plotshape(sellSignal, title="SELL Signal", location=location.abovebar,
     color=color.red, style=shape.triangledown, size=size.tiny)

// === BEARISH CROSS (EMA crosses below DEMA) ===
bearCross = ta.crossunder(ema, dema)

plotshape(bearCross, title="Bearish Cross", location=location.belowbar,
     color=color.rgb(6, 164, 255), style=shape.triangledown, size=size.small)
